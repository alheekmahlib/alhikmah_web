# Cloudflare Pages headers
# تكوين CSP للسماح بتحميل iframe مشروع القرآن + الصور من GitHub

/*
  Content-Security-Policy: frame-ancestors 'self'; frame-src 'self' https://*.alheekmahlib.com http://localhost:* https://localhost:*; img-src 'self' data: https:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https://raw.githubusercontent.com https://pub-527cd05a026a41dc9348c1e0c66bc0a6.r2.dev https://formsubmit.co;
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
